<?xml version="1.0" encoding="utf-8"?>
<keyboard name="QWERTY Custom" script="latin">
  <!-- Row 1: Numbers -->
  <row>
    <key key0="1" key1="loc esc" key2="!" key4="`"/>
    <key key0="2" key2="@" key3="~"/>
    <key key0="3" key2="#"/>
    <key key0="4" key2="$"/>
    <key key0="5" key2="%"/>
    <key key0="6" key2="^"/>
    <key key0="7" key2="&amp;"/>
    <key key0="8" key2="*"/>
    <key key0="9" key1="-" key3="_"/>
    <key key0="0" key1="+" key3="="/>
  </row>
  <!-- Row 2: QWERTY (q-p) -->
  <row>
    <key key0="q"/>
    <key key0="w"/>
    <key key0="e"/>
    <key key0="r"/>
    <key key0="t"/>
    <key key0="y" key2="redo" key3="&lt;" key4="&gt;"/>
    <key key0="u" key3="(" key4=")"/>
    <key key0="i" key3="{" key4="}"/>
    <key key0="o" key3="[" key4="]"/>
    <key key0="p" key1="\\" key3="|"/>
  </row>
  <!-- Row 3: QWERTY (a-l) -->
  <row>
    <key shift="0.5" key0="a" key1="loc tab" key2="selectAll" key3="menu"/>
    <key key0="s"/>
    <key key0="d"/>
    <key key0="f"/>
    <key key0="g"/>
    <key key0="h"/>
    <key key0="j"/>
    <key key0="k" key3=";" key4=":"/>
    <key key0="l" key3="'" key4="&quot;"/>
  </row>
  <!-- Row 4: QWERTY (z-m) -->
  <row>
    <key width="1.5" key0="shift" key2="loc capslock"/>
    <key key0="z" key2="undo"/>
    <key key0="x" key2="cut"/>
    <key key0="c" key2="copy"/>
    <key key0="v" key2="paste"/>
    <key key0="b" key2="pasteAsPlainText"/>
    <key key0="n" key1="&quot;" key2="."/>
    <key key0="m" key1="/" key2="?"/>
    <key width="1.5" key0="backspace" key2="delete"/>
  </row>
</keyboard>
