<?xml version="1.0" encoding="utf-8"?>
<keyboard name="두벌식 (Korean)" script="hangul">
  <!-- Row 1: Numbers -->
  <row>
    <key key0="1" key1="loc esc" key2="!" key4="`"/>
    <key key0="2" key2="@" key3="~"/>
    <key key0="3" key2="#"/>
    <key key0="4" key2="$"/>
    <key key0="5" key2="%"/>
    <key key0="6" key2="^"/>
    <key key0="7" key2="&amp;"/>
    <key key0="8" key2="*"/>
    <key key0="9" key1="-" key3="_"/>
    <key key0="0" key1="+" key3="="/>
  </row>
  <!-- Row 2: Korean jamo (QWERTY q-p) -->
  <row>
    <key key0="ㅂ"/>
    <key key0="ㅈ"/>
    <key key0="ㄷ"/>
    <key key0="ㄱ"/>
    <key key0="ㅅ"/>
    <key key0="ㅛ" key2="redo" key3="&lt;" key4="&gt;"/>
    <key key0="ㅕ" key3="(" key4=")"/>
    <key key0="ㅑ" key3="{" key4="}"/>
    <key key0="ㅐ" key3="[" key4="]"/>
    <key key0="ㅔ" key1="\\" key3="|"/>
  </row>
  <!-- Row 3: Korean jamo (QWERTY a-l) -->
  <row>
    <key shift="0.5" key0="ㅁ" key1="loc tab" key2="selectAll" key3="menu"/>
    <key key0="ㄴ"/>
    <key key0="ㅇ"/>
    <key key0="ㄹ"/>
    <key key0="ㅎ"/>
    <key key0="ㅗ"/>
    <key key0="ㅓ"/>
    <key key0="ㅏ" key3=";" key4=":"/>
    <key key0="ㅣ" key3="'" key4="&quot;"/>
  </row>
  <!-- Row 4: Korean jamo (QWERTY z-m) -->
  <row>
    <key width="1.5" key0="shift" key2="loc capslock"/>
    <key key0="ㅋ" key2="undo"/>
    <key key0="ㅌ" key2="cut"/>
    <key key0="ㅊ" key2="copy"/>
    <key key0="ㅍ" key2="paste"/>
    <key key0="ㅠ" key2="pasteAsPlainText"/>
    <key key0="ㅜ" key1="&quot;" key2="."/>
    <key key0="ㅡ" key1="/" key2="?"/>
    <key width="1.5" key0="backspace" key2="delete"/>
  </row>
</keyboard>
